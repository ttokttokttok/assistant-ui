{
  "manifest_version": 3,
  "name": "assistant-ui Browser Extension Example",
  "version": "0.1.0",
  "description": "Example Chrome extension with assistant-ui chat in a side panel",
  "permissions": ["sidePanel"],
  "action": {
    "default_title": "Open assistant-ui Chat"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
