{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./app/*"]
    }
  },
  "include": [
    "app/next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "server/**/*.ts",
    "app/.next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
